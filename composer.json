{
    "name": "your-org/my-village-hall",
    "description": "My Village Hall WordPress plugin",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.1",
        "dompdf/dompdf": "^3.1",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "php-stubs/wordpress-stubs": "^6.9",
        "fakerphp/faker": "^1.24"
    },
    "autoload": {
        "psr-4": {
            "MYVH\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MYVH\\Tests\\Unit\\": "tests/Unit/",
            "MYVH\\Tests\\stubs\\": "tests/stubs/",
            "Tests\\Support\\Factories\\": "tests/Support/Factories/",
            "Tests\\Support\\Seeders\\": "tests/Support/Seeders/"
        }
    },
    "scripts": {
        "test":      "./vendor/bin/phpunit",
        "test:unit": "./vendor/bin/phpunit --testsuite Unit"
    },
    "config": {
        "optimize-autoloader": true
    }
}
