{
    "name": "your-org/my-village-hall",
    "description": "My Village Hall WordPress plugin",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "classmap": [
            "core/",
            "modules/"
        ],
        "psr-4": {
            "MYVH\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MYVH\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":      "./vendor/bin/phpunit",
        "test:unit": "./vendor/bin/phpunit --testsuite Unit"
    },
    "config": {
        "optimize-autoloader": true
    }
}
